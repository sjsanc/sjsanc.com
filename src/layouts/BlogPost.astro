---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import ArrowLeft from '@lucide/astro/icons/arrow-left';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class="bg-slate-50 text-black antialiased">
    <main class="max-w-2xl mx-auto px-6 py-20">
      <a href="/" class="inline-flex items-center gap-1.5 text-sm text-neutral-400 hover:text-black transition-colors mb-10">
        <ArrowLeft size={14} />Back
      </a>
      <article>
        <header class="mb-12">
          <h1 class="text-4xl font-semibold tracking-tight leading-tight mb-2">{title}</h1>
          <time class="text-sm text-neutral-500" datetime={pubDate.toISOString()}>
            {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {updatedDate && (
            <p class="text-sm text-neutral-500 italic mt-1">
              Updated {updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
          )}
        </header>
        <div class="prose prose-neutral max-w-none">
          <slot />
        </div>
      </article>
    </main>
  </body>
</html>
