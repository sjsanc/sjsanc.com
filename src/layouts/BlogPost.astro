---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import ArrowLeft from "@lucide/astro/icons/arrow-left";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate } = Astro.props;
---

<html lang="en">
    <head>
        <BaseHead title={title} description={description} />
        <style>
            .neo-link {
                background: white;
                transform: translate(-4px, -4px);
                transition: transform 0.1s ease;
            }
            .neo-link:hover {
                transform: translate(-2px, -2px);
            }
            .neo-link:active {
                transform: translate(0, 0);
            }
        </style>
    </head>
    <body
        class="bg-zinc-900 text-black antialiased p-2 min-h-screen"
        style="background-color: #18181b; background-image: radial-gradient(circle at 50% 100%, transparent 20%, #27272a 21%, #27272a 34%, transparent 35%, transparent), radial-gradient(circle at 50% 0%, transparent 20%, #27272a 21%, #27272a 34%, transparent 35%, transparent); background-position: 0 0, -10px 0; background-size: 20px 15px;"
    >
        <main
            class="max-w-[680px] bg-white flex flex-col mx-auto p-4 rounded-2xl"
            style="box-shadow: 6px 6px 0 0 #18181b;"
        >
            <div
                class="rounded-xl border-4 p-6 border-zinc-900 flex flex-col gap-6"
            >
                <div class="bg-zinc-900 rounded-lg self-start">
                    <a
                        href="/"
                        class="neo-link border-3 border-zinc-900 flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm"
                    >
                        <ArrowLeft size={14} />Back
                    </a>
                </div>
                <header>
                    <h1
                        class="text-3xl font-semibold tracking-tight leading-tight mb-2"
                    >
                        {title}
                    </h1>
                    <time
                        class="text-sm text-neutral-500"
                        datetime={pubDate.toISOString()}
                    >
                        {
                            pubDate.toLocaleDateString("en-US", {
                                year: "numeric",
                                month: "long",
                                day: "numeric",
                            })
                        }
                    </time>
                    {
                        updatedDate && (
                            <p class="text-sm text-neutral-500 italic mt-1">
                                Updated{" "}
                                {updatedDate.toLocaleDateString("en-US", {
                                    year: "numeric",
                                    month: "long",
                                    day: "numeric",
                                })}
                            </p>
                        )
                    }
                </header>
                <div class="prose prose-neutral max-w-none">
                    <slot />
                </div>
            </div>
        </main>
    </body>
</html>
